# DB export credentials — copy to /etc/fsbackup/db/<appname>.env
# This file is sourced by fs-db-export.sh. Never commit the live file.

DB_ENGINE=mariadb          # mariadb, mysql, or postgres
DB_CONTAINER=myapp_db_1    # docker container name running the DB
DB_NAME=myapp              # database name to export
DB_USER=myapp              # DB user
DB_PASSWORD=changeme       # DB password
EXPORT_ROOT=/var/lib/fsbackup/db-exports/myapp   # where to write the .sql.gz
# BACKUP_USER=backup       # optional; default is "backup"
