[Unit]
Description=fsbackup supercronic scheduler
After=network.target
Documentation=https://github.com/aptible/supercronic

[Service]
Type=simple
User=fsbackup
EnvironmentFile=-/etc/fsbackup/fsbackup.conf
ExecStart=/usr/local/bin/supercronic /etc/fsbackup/fsbackup.crontab
Restart=on-failure
RestartSec=30

# Ensure job output goes to the journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fsbackup-scheduler

[Install]
WantedBy=multi-user.target
