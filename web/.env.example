# fsbackup web UI — environment configuration
# Copy to web/.env and edit. All values shown are the defaults.
# When running under systemd, these can also be set via Environment= in the unit file.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# ---------------------------------------------------------------------------
# Snapshot paths (must match fsbackup.conf)
# ---------------------------------------------------------------------------
SNAPSHOT_ROOT=/backup/snapshots
MIRROR_ROOT=/backup2/snapshots
TARGETS_FILE=/etc/fsbackup/targets.yml

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Set AUTH_ENABLED=false to disable login (useful on a trusted private network).
# When enabled, users authenticate with their Linux system account via PAM.
AUTH_ENABLED=true

# Stable secret key for session cookies. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# If unset, a random key is generated at startup (sessions reset on restart).
# SECRET_KEY=changeme

# ---------------------------------------------------------------------------
# S3 offsite
# ---------------------------------------------------------------------------
S3_BUCKET=fsbackup-snapshots-SUFFIX
S3_PROFILE=fsbackup
S3_REGION=us-west-2
# Presigned download URL lifetime in seconds (default 3600 = 1 hour)
# PRESIGN_TTL=3600
