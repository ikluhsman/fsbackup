# fsbackup web UI — environment configuration
# Copy to web/.env and edit. All values shown are the defaults.
# When running under systemd, these can also be set via Environment= in the unit file.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# ---------------------------------------------------------------------------
# Snapshot paths (must match fsbackup.conf)
# ---------------------------------------------------------------------------
SNAPSHOT_ROOT=/backup/snapshots
MIRROR_ROOT=/backup2/snapshots
TARGETS_FILE=/etc/fsbackup/targets.yml

# ---------------------------------------------------------------------------
# S3 offsite
# ---------------------------------------------------------------------------
S3_BUCKET=fsbackup-snapshots-947012
S3_PROFILE=fsbackup
S3_REGION=us-west-2
# Presigned download URL lifetime in seconds (default 3600 = 1 hour)
# PRESIGN_TTL=3600
